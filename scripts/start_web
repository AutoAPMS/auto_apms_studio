#!/usr/bin/env python3

import argparse
import http.server
import os
import sys

from ament_index_python.packages import get_package_share_directory

BASE_PATH = "/auto_apms_studio"


class _Handler(http.server.SimpleHTTPRequestHandler):
    """Serve files from *frontend_dist_dir* under the ``/auto_apms_studio/`` prefix."""

    def translate_path(self, path):
        # Strip the Vite base prefix so that /auto_apms_studio/assets/… resolves
        # to <dist>/assets/… instead of <dist>/auto_apms_studio/assets/…
        if path == BASE_PATH or path.startswith(BASE_PATH + "/"):
            path = path[len(BASE_PATH) :] or "/"
        return super().translate_path(path)

    def log_message(self, fmt, *args):  # noqa: D401
        print(f"{self.address_string()} - {fmt % args}", file=sys.stderr)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Start the Auto APMS Studio web server"
    )
    parser.add_argument(
        "--host",
        type=str,
        default=os.getenv("AUTO_APMS_STUDIO_WEB_HOST", "0.0.0.0"),
        help="Host to bind to (default: Environment variable AUTO_APMS_STUDIO_WEB_HOST, fall back to 0.0.0.0)",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=os.getenv("AUTO_APMS_STUDIO_WEB_PORT", "5173"),
        help="Port to bind to (default: Environment variable AUTO_APMS_STUDIO_WEB_PORT, fall back to 5173)",
    )
    args = parser.parse_args()

    share_dir = get_package_share_directory("auto_apms_studio")
    frontend_dist_dir = os.path.join(share_dir, "web", "dist")

    if not os.path.isdir(frontend_dist_dir) or not os.path.isfile(
        os.path.join(frontend_dist_dir, "index.html")
    ):
        print(f"ERROR: Built frontend not found at: {frontend_dist_dir}")
        print(
            "Please rebuild the package: colcon build --packages-select auto_apms_studio"
        )
        sys.exit(1)

    # Change to the dist directory so SimpleHTTPRequestHandler resolves paths correctly
    os.chdir(frontend_dist_dir)

    handler = _Handler
    handler.directory = frontend_dist_dir

    print("Starting AutoAPMS Studio web server:")
    print(f"Serving at http://{args.host}:{args.port}{BASE_PATH}/")

    with http.server.HTTPServer((args.host, args.port), handler) as httpd:
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            pass
