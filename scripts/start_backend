#!/usr/bin/env python3

import os
import argparse
import uvicorn

if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Start the AutoAPMS Studio backend server"
    )
    parser.add_argument(
        "--host",
        type=str,
        default=os.getenv("AUTO_APMS_STUDIO_BACKEND_HOST", "0.0.0.0"),
        help="Host to bind to (default: Environment variable AUTO_APMS_STUDIO_BACKEND_HOST, fall back to 0.0.0.0)",
    )
    parser.add_argument(
        "--port",
        type=int,
        default=8000,
        help="Port to bind to (default: Environment variable AUTO_APMS_STUDIO_BACKEND_PORT, fall back to 8000)",
    )
    parser.add_argument("--log-level", default="info", help="Log level (default: info)")
    args = parser.parse_args()

    print("Starting AutoAPMS Studio backend server:")
    uvicorn.run(
        "auto_apms_studio.backend.app.main:app",
        host=args.host,
        port=args.port,
        log_level=args.log_level,
    )
